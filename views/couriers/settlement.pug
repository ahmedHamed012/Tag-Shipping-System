extends ../layouts/layout

block content
  .container-fluid.py-4

    // ── Header ──────────────────────────────────────────────────────────
    .row.mb-4
      .col-md-8
        h2.mb-0
          i.bi.bi-percent.me-2
          | تقفيل المناديب
      .col-md-4.text-end
        button#printBtn.btn.btn-outline-secondary.me-2(type="button" style="display:none")
          i.bi.bi-printer.me-2
          | طباعة
        button#saveBtn.btn.btn-success(type="button" style="display:none" disabled)
          i.bi.bi-lock-fill.me-2
          | حفظ التقفيل

    // ── Filters ─────────────────────────────────────────────────────────
    .card.mb-4
      .card-body
        .row.g-3.align-items-end
          .col-md-4
            label.form-label اختر الساعي
              span.text-danger *
            select#courierSelect.form-select
              option(value="") -- اختر الساعي --
          .col-md-3
            label.form-label من تاريخ
            input#startDate.form-control(type="date")
          .col-md-3
            label.form-label إلى تاريخ
            input#endDate.form-control(type="date")
          .col-md-2
            button#filterBtn.btn.btn-primary.w-100(type="button")
              i.bi.bi-funnel.me-2
              | تطبيق

    // ── Stats cards ──────────────────────────────────────────────────────
    #settlementStats(style="display:none")
      .row.g-3.mb-4
        .col-6.col-md
          .card.text-center.border-0.shadow-sm
            .card-body.py-3
              .fs-2.fw-bold.text-dark#statTotal 0
              .small.text-muted إجمالي الشحنات
        .col-6.col-md
          .card.text-center.border-0.shadow-sm
            .card-body.py-3
              .fs-2.fw-bold.text-success#statDelivered 0
              .small.text-muted تم التوصيل
        .col-6.col-md
          .card.text-center.border-0.shadow-sm
            .card-body.py-3
              .fs-2.fw-bold.text-warning#statPartialEx 0
              .small.text-muted جزئي / استبدال
        .col-6.col-md
          .card.text-center.border-0.shadow-sm
            .card-body.py-3
              .fs-2.fw-bold.text-danger#statReturned 0
              .small.text-muted مرتجع
        .col-6.col-md
          .card.text-center.border-0.shadow-sm
            .card-body.py-3
              .fs-2.fw-bold.text-info#statStillOut 0
              .small.text-muted قيد التوصيل

    // ── Financial summary ────────────────────────────────────────────────
    #financialSummary(style="display:none")
      .card.mb-4.border-success
        .card-header.bg-success.text-white
          h6.mb-0
            i.bi.bi-cash-stack.me-2
            | الملخص المالي
        .card-body
          .row.g-3
            .col-md-3
              .p-3.bg-light.rounded.text-center
                .small.text-muted.mb-1 إجمالي المحصل من العملاء
                .fs-4.fw-bold.text-primary
                  span#finCollected 0.00
                  small.ms-1 ج.م
            .col-md-3
              .p-3.bg-light.rounded.text-center
                .small.text-muted.mb-1
                  | عمولة الساعي
                  span.text-muted.ms-1 (
                  span#feeLabel -
                  span.text-muted ) ×
                  span#settleableCount 0
                  span.text-muted  شحنة
                .fs-4.fw-bold.text-warning
                  span#finEarnings 0.00
                  small.ms-1 ج.م
            .col-md-3
              .p-3.bg-light.rounded.text-center
                .small.text-muted.mb-1 صافي التسليم للشركة
                .fs-4.fw-bold.text-success
                  span#finHandover 0.00
                  small.ms-1 ج.م
            .col-md-3
              .p-3.bg-light.rounded.text-center
                #noFeeWarning(style="display:none")
                  .alert.alert-warning.py-2.mb-0.small
                    i.bi.bi-exclamation-triangle.me-1
                    | لم يتم تحديد عمولة للساعي
                #feeOk(style="display:none")
                  .alert.alert-success.py-2.mb-0.small
                    i.bi.bi-check-circle.me-1
                    | جاهز للتقفيل
                  .mt-2
                    label.form-label.small.mb-1 ملاحظات (اختياري)
                    textarea#settlementNotes.form-control.form-control-sm(rows="2" placeholder="ملاحظات حول هذا التقفيل...")

    // ── Shipment tables ──────────────────────────────────────────────────
    #shipmentTables(style="display:none")
      .row.g-4

        .col-lg-6
          .card.h-100
            .card-header.bg-success.text-white.d-flex.justify-content-between.align-items-center
              h6.mb-0
                i.bi.bi-check-circle.me-2
                | تم التوصيل
              span.badge.bg-white.text-success#badgeDelivered 0
            .card-body.p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead.table-light
                    tr
                      th رقم الشحنة
                      th العميل
                      th المنطقة
                      th.text-end محصل
                  tbody#listDelivered
                    tr
                      td.text-center.text-muted.py-3(colspan="4") لا توجد شحنات

        .col-lg-6
          .card.h-100
            .card-header.bg-warning.text-dark.d-flex.justify-content-between.align-items-center
              h6.mb-0
                i.bi.bi-arrow-left-right.me-2
                | جزئي / استبدال
              span.badge.bg-white.text-warning#badgePartialEx 0
            .card-body.p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead.table-light
                    tr
                      th رقم الشحنة
                      th العميل
                      th الحالة
                      th.text-end محصل
                  tbody#listPartialEx
                    tr
                      td.text-center.text-muted.py-3(colspan="4") لا توجد شحنات

        .col-lg-6
          .card.h-100
            .card-header.bg-danger.text-white.d-flex.justify-content-between.align-items-center
              h6.mb-0
                i.bi.bi-x-circle.me-2
                | مرتجع
              span.badge.bg-white.text-danger#badgeReturned 0
            .card-body.p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead.table-light
                    tr
                      th رقم الشحنة
                      th العميل
                      th المنطقة
                      th الحالة
                  tbody#listReturned
                    tr
                      td.text-center.text-muted.py-3(colspan="4") لا توجد شحنات

        .col-lg-6
          .card.h-100
            .card-header.bg-info.text-white.d-flex.justify-content-between.align-items-center
              h6.mb-0
                i.bi.bi-truck.me-2
                | قيد التوصيل (لن تُقفَّل)
              span.badge.bg-white.text-info#badgeStillOut 0
            .card-body.p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead.table-light
                    tr
                      th رقم الشحنة
                      th العميل
                      th المنطقة
                      th.text-end إجمالي
                  tbody#listStillOut
                    tr
                      td.text-center.text-muted.py-3(colspan="4") لا توجد شحنات

    // ── Settlement History ───────────────────────────────────────────────
    #settlementHistory(style="display:none")
      hr.my-4
      .d-flex.justify-content-between.align-items-center.mb-3
        h5.mb-0
          i.bi.bi-clock-history.me-2
          | سجل التقفيلات السابقة
      .table-responsive
        table.table.table-sm.table-hover
          thead.table-light
            tr
              th # التقفيل
              th الفترة
              th عدد الشحنات
              th إجمالي محصل
              th عمولة الساعي
              th صافي للشركة
              th تاريخ الحفظ
          tbody#historyTableBody

  script.
    let currentCourierId = null;
    let currentData = null;

    document.addEventListener('DOMContentLoaded', () => {
      const today = new Date().toISOString().split('T')[0];
      document.getElementById('startDate').value = today;
      document.getElementById('endDate').value   = today;

      loadCouriersDropdown();

      document.getElementById('courierSelect').addEventListener('change', function() {
        currentCourierId = this.value || null;
        if (currentCourierId) {
          loadSettlement();
          loadHistory();
        } else {
          hideSections();
        }
      });

      document.getElementById('filterBtn').addEventListener('click', () => {
        if (currentCourierId) loadSettlement();
        else alert('اختر ساعياً أولاً');
      });

      document.getElementById('saveBtn').addEventListener('click', saveSettlement);
      document.getElementById('printBtn').addEventListener('click', () => window.print());
    });

    // ── Data loaders ──────────────────────────────────────────────────────

    async function loadCouriersDropdown() {
      const res  = await fetch('/couriers/api/dropdown');
      const data = await res.json();
      if (!data.success) return;
      const select = document.getElementById('courierSelect');
      select.innerHTML = '<option value="">-- اختر الساعي --</option>';
      data.data.forEach(c => {
        const o = document.createElement('option');
        o.value = c.id; o.textContent = c.fullName;
        select.appendChild(o);
      });
    }

    async function loadSettlement() {
      const start = document.getElementById('startDate').value;
      const end   = document.getElementById('endDate').value;
      const params = new URLSearchParams({ startDate: start, endDate: end });

      const res  = await fetch(`/couriers/api/settlement/${currentCourierId}?${params}`);
      const data = await res.json();
      if (!data.success) { alert('خطأ: ' + data.error); return; }

      currentData = data.data;
      renderSettlement(data.data);
    }

    async function loadHistory() {
      const res  = await fetch(`/couriers/api/settlement/${currentCourierId}/history`);
      const data = await res.json();
      if (!data.success) return;
      renderHistory(data.settlements);
    }

    async function saveSettlement() {
      if (!currentCourierId || !currentData) return;
      if (!confirm('هل تريد حفظ وقفل هذا التقفيل؟ لن يمكن التراجع عنه.')) return;

      const notes = document.getElementById('settlementNotes').value;
      const start = document.getElementById('startDate').value;
      const end   = document.getElementById('endDate').value;

      const res  = await fetch(`/couriers/api/settlement/${currentCourierId}/save`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ startDate: start, endDate: end, notes }),
      });
      const data = await res.json();

      if (data.success) {
        showToast('success', data.message);
        loadSettlement();
        loadHistory();
      } else {
        showToast('error', data.error);
      }
    }

    // ── Renderers ─────────────────────────────────────────────────────────

    function renderSettlement(d) {
      show('settlementStats');
      show('financialSummary');
      show('shipmentTables');
      show('printBtn');

      // Stats
      document.getElementById('statTotal').textContent     = d.stats.total;
      document.getElementById('statDelivered').textContent = d.stats.delivered;
      document.getElementById('statPartialEx').textContent = d.stats.partialEx;
      document.getElementById('statReturned').textContent  = d.stats.returned;
      document.getElementById('statStillOut').textContent  = d.stats.stillOut;

      // Financial
      const f = d.financial;
      document.getElementById('finCollected').textContent  = f.totalCollected.toFixed(2);
      document.getElementById('finEarnings').textContent   = f.courierEarnings.toFixed(2);
      document.getElementById('finHandover').textContent   = f.netHandover.toFixed(2);
      document.getElementById('feeLabel').textContent      = f.feePerShipment.toFixed(2) + ' ج.م';
      document.getElementById('settleableCount').textContent = d.stats.settleable;

      const hasFee = f.feePerShipment > 0;
      document.getElementById('noFeeWarning').style.display = hasFee ? 'none' : '';
      document.getElementById('feeOk').style.display        = hasFee ? '' : 'none';

      const canSave = d.stats.settleable > 0;
      const saveBtn = document.getElementById('saveBtn');
      saveBtn.style.display = '';
      saveBtn.disabled = !canSave;

      // Tables
      renderTable('listDelivered',  'badgeDelivered',  d.groups.delivered,  rowDelivered);
      renderTable('listPartialEx',  'badgePartialEx',  d.groups.partialEx,  rowPartialEx);
      renderTable('listReturned',   'badgeReturned',   d.groups.returned,   rowReturned);
      renderTable('listStillOut',   'badgeStillOut',   d.groups.stillOut,   rowStillOut);
    }

    function renderTable(tbodyId, badgeId, items, rowFn) {
      const cols = { listDelivered:4, listPartialEx:4, listReturned:4, listStillOut:4 };
      document.getElementById(badgeId).textContent = items.length;
      const tbody = document.getElementById(tbodyId);
      tbody.innerHTML = items.length
        ? items.map(rowFn).join('')
        : `<tr><td class="text-center text-muted py-3" colspan="${cols[tbodyId]}">لا توجد شحنات</td></tr>`;
    }

    const pn = s => s.policyNumber || ('SH-' + s.id);
    const loc = s => [s.receiver?.governorate, s.receiver?.city].filter(Boolean).join(' - ') || '-';
    const amt = v => parseFloat(v || 0).toFixed(2);

    function rowDelivered(s) {
      return `<tr>
        <td><span class="badge bg-info">${pn(s)}</span></td>
        <td>${s.receiver?.fullName || '-'}<br><small class="text-muted">${s.receiver?.phone1 || ''}</small></td>
        <td><small>${loc(s)}</small></td>
        <td class="text-end fw-bold text-success">${amt(s.deliveryCollectedAmount)} ج.م</td>
      </tr>`;
    }

    function rowPartialEx(s) {
      return `<tr>
        <td><span class="badge bg-info">${pn(s)}</span></td>
        <td>${s.receiver?.fullName || '-'}</td>
        <td><span class="badge bg-secondary">${s.shipmentStatus}</span></td>
        <td class="text-end fw-bold text-warning">${amt(s.deliveryCollectedAmount)} ج.م</td>
      </tr>`;
    }

    function rowReturned(s) {
      return `<tr>
        <td><span class="badge bg-info">${pn(s)}</span></td>
        <td>${s.receiver?.fullName || '-'}</td>
        <td><small>${loc(s)}</small></td>
        <td><span class="badge bg-danger">${s.shipmentStatus}</span></td>
      </tr>`;
    }

    function rowStillOut(s) {
      return `<tr>
        <td><span class="badge bg-info">${pn(s)}</span></td>
        <td>${s.receiver?.fullName || '-'}</td>
        <td><small>${loc(s)}</small></td>
        <td class="text-end">${amt(s.totalAmount)} ج.م</td>
      </tr>`;
    }

    function renderHistory(settlements) {
      const section = document.getElementById('settlementHistory');
      const tbody   = document.getElementById('historyTableBody');
      if (!settlements.length) { section.style.display = 'none'; return; }

      show('settlementHistory');
      tbody.innerHTML = settlements.map(s => `
        <tr>
          <td><span class="badge bg-secondary">#${s.id}</span></td>
          <td><small>${fmt(s.periodFrom)} → ${fmt(s.periodTo)}</small></td>
          <td class="text-center">${s.shipmentCount}</td>
          <td class="text-end">${parseFloat(s.totalCollected).toFixed(2)} ج.م</td>
          <td class="text-end">${parseFloat(s.courierEarnings).toFixed(2)} ج.م</td>
          <td class="text-end fw-bold text-success">${parseFloat(s.netHandover).toFixed(2)} ج.م</td>
          <td><small>${fmt(s.createdAt)}</small></td>
        </tr>`).join('');
    }

    // ── Helpers ───────────────────────────────────────────────────────────

    function fmt(d) { return new Date(d).toLocaleDateString('ar-EG'); }
    function show(id) { document.getElementById(id).style.display = ''; }
    function hideSections() {
      ['settlementStats','financialSummary','shipmentTables','settlementHistory','printBtn','saveBtn']
        .forEach(id => { const el = document.getElementById(id); if (el) el.style.display = 'none'; });
    }

    function showToast(type, msg) {
      const d = document.createElement('div');
      d.className = `alert alert-${type === 'error' ? 'danger' : 'success'} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
      d.style.zIndex = 9999;
      d.innerHTML = `${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
      document.body.appendChild(d);
      setTimeout(() => d.remove(), 5000);
    }
