extends ../layouts/layout

block content
  .container-fluid

    //- ════════════════════════════════════════
    //- PAGE HEADER
    //- ════════════════════════════════════════
    .row.mb-4
      .col-12
        .d-flex.justify-content-between.align-items-center
          div
            h1.mb-2 إدارة المستخدمين
            p.text-muted عدد المستخدمين: 
              strong= totalUsers
          div.d-flex.gap-2
            button.btn.btn-primary(data-bs-toggle="modal", data-bs-target="#addUserModal")
              i.bi.bi-plus-circle.me-2
              | إضافة مستخدم جديد
            button.btn.btn-success(onclick="downloadTemplate()")
              i.bi.bi-download.me-2
              | تحميل قالب Excel
            button.btn.btn-info(data-bs-toggle="modal", data-bs-target="#uploadExcelModal")
              i.bi.bi-upload.me-2
              | رفع من Excel

    //- ════════════════════════════════════════
    //- SEARCH & FILTER BAR
    //- ════════════════════════════════════════
    .row.mb-3
      .col-12
        .card
          .card-body.pb-0
            form.row.g-3(method="GET", action="/users")
              .col-md-6
                input.form-control(
                  type="text",
                  name="search",
                  placeholder="ابحث بالاسم أو البريد الإلكتروني أو الهاتف...",
                  value=search
                )
              .col-md-3
                select.form-select(name="limit")
                  option(value="10", selected=limit==10) 10 صفوف لكل صفحة
                  option(value="20", selected=limit==20) 20 صفوف لكل صفحة
                  option(value="50", selected=limit==50) 50 صفوف لكل صفحة
              .col-md-3
                button.btn.btn-outline-primary.w-100(type="submit")
                  i.bi.bi-search.me-2
                  | بحث

    //- ════════════════════════════════════════
    //- USERS TABLE
    //- ════════════════════════════════════════
    .row
      .col-12
        .card
          .table-responsive
            table.table.table-hover.mb-0
              thead.table-light
                tr
                  th الاسم الكامل
                  th البريد الإلكتروني
                  th رقم الهاتف
                  th الدور
                  th الحالة
                  th تاريخ الإنشاء
                  th الإجراءات

              tbody
                if users.length > 0
                  each user in users
                    tr
                      td
                        .d-flex.align-items-center.gap-3
                          if user.profilePicture
                            img.rounded-circle(
                              src=user.profilePicture,
                              alt="صورة الملف الشخصي",
                              style="width: 40px; height: 40px; object-fit: cover; border: 2px solid #e9ecef;"
                            )
                          else
                            .bg-light.rounded-circle.d-flex.align-items-center.justify-content-center(
                              style="width: 40px; height: 40px; border: 2px solid #e9ecef;"
                            )
                              i.bi.bi-person.text-muted
                          .d-flex.flex-column
                            strong.mb-0= user.fullName
                      td
                        small= user.email
                      td
                        small= user.phone
                      td
                        if user.role === "ADMIN"
                          span.badge.bg-danger إدارة
                        else if user.role === "CUSTOMER_SERVICE"
                          span.badge.bg-warning خدمة العملاء
                        else
                          span.badge.bg-info العمليات

                      td
                        if user.isActive
                          span.badge.bg-success نشط
                        else
                          span.badge.bg-secondary معطل

                      td
                        small= new Date(user.createdAt).toLocaleDateString("ar-SA")

                      td
                        .btn-group(role="group")
                          button.btn.btn-sm.btn-outline-primary(
                            onclick=`editUser(${user.id})`
                          )
                            i.bi.bi-pencil

                          button.btn.btn-sm.btn-outline-warning(
                            onclick=`toggleStatus(${user.id})`
                          )
                            if user.isActive
                              i.bi.bi-toggle-on
                            else
                              i.bi.bi-toggle-off

                          button.btn.btn-sm.btn-outline-danger(
                            onclick=`deleteUser(${user.id})`
                          )
                            i.bi.bi-trash

                else
                  tr
                    td.text-center.text-muted(colspan="7")
                      i.bi.bi-inbox.me-2(style="font-size: 2rem;")
                      br
                      | لا توجد مستخدمين للعرض

          //- PAGINATION
          if totalPages > 1
            .card-footer.bg-light
              nav
                ul.pagination.justify-content-center.mb-0
                  li.page-item(class=currentPage===1 ? "disabled" : "")
                    a.page-link(href=`/users?page=1&search=${search}&limit=${limit}`)
                      | الأولى

                  li.page-item(class=currentPage===1 ? "disabled" : "")
                    a.page-link(href=`/users?page=${currentPage-1}&search=${search}&limit=${limit}`)
                      | السابقة

                  - for(let i = Math.max(1, currentPage-2); i <= Math.min(totalPages, currentPage+2); i++)
                    li.page-item(class=i===currentPage ? "active" : "")
                      a.page-link(href=`/users?page=${i}&search=${search}&limit=${limit}`)= i

                  li.page-item(class=currentPage===totalPages ? "disabled" : "")
                    a.page-link(href=`/users?page=${currentPage+1}&search=${search}&limit=${limit}`)
                      | التالية

                  li.page-item(class=currentPage===totalPages ? "disabled" : "")
                    a.page-link(href=`/users?page=${totalPages}&search=${search}&limit=${limit}`)
                      | الأخيرة

    include ./_formModal
    include ./_uploadExcelModal

  script.
    // Edit user
    async function editUser(userId) {
      try {
        const response = await fetch(`/users/api/get/${userId}`);
        const data = await response.json();

        if (!data.success) {
          showAlert("خطأ", data.error, "error");
          return;
        }

        const user = data.user;
        document.getElementById("modalTitle").textContent = "تعديل المستخدم";
        document.getElementById("userId").value = user.id;
        document.getElementById("fullName").value = user.fullName;
        document.getElementById("email").value = user.email;
        document.getElementById("phone").value = user.phone;
        document.getElementById("address").value = user.address || "";
        document.getElementById("nationalId").value = user.nationalId;
        document.getElementById("role").value = user.role;
        document.getElementById("password").value = "";
        document.getElementById("password").placeholder = "اتركها فارغة للاحتفاظ بالكلمة السرية الحالية";

        // Handle attachments display
        const profilePicContainer = document.getElementById("currentProfilePictureContainer");
        const profilePicImg = document.getElementById("currentProfilePicture");
        if (user.profilePicture) {
          profilePicImg.src = user.profilePicture;
          profilePicContainer.style.display = "block";
        } else {
          profilePicContainer.style.display = "none";
        }

        const idFrontContainer = document.getElementById("currentIdCardFrontContainer");
        const idFrontImg = document.getElementById("currentIdCardFront");
        if (user.idCardFront) {
          idFrontImg.src = user.idCardFront;
          idFrontContainer.style.display = "block";
        } else {
          idFrontContainer.style.display = "none";
        }

        const idBackContainer = document.getElementById("currentIdCardBackContainer");
        const idBackImg = document.getElementById("currentIdCardBack");
        if (user.idCardBack) {
          idBackImg.src = user.idCardBack;
          idBackContainer.style.display = "block";
        } else {
          idBackContainer.style.display = "none";
        }

        const modal = new bootstrap.Modal(document.getElementById("addUserModal"));
        modal.show();
      } catch (error) {
        showAlert("خطأ", error.message, "error");
      }
    }

    // Save user
    async function saveUser() {
      const userId = document.getElementById("userId").value;
      const fullName = document.getElementById("fullName").value;
      const email = document.getElementById("email").value;
      const phone = document.getElementById("phone").value;
      const address = document.getElementById("address").value;
      const nationalId = document.getElementById("nationalId").value;
      const role = document.getElementById("role").value;
      const password = document.getElementById("password").value;

      // Create FormData for file uploads
      const formData = new FormData();
      formData.append("fullName", fullName);
      formData.append("email", email);
      formData.append("phone", phone);
      formData.append("address", address);
      formData.append("nationalId", nationalId);
      formData.append("role", role);
      if (password) formData.append("password", password);

      // Add files if selected
      const profilePicture = document.getElementById("profilePicture").files[0];
      const idCardFront = document.getElementById("idCardFront").files[0];
      const idCardBack = document.getElementById("idCardBack").files[0];

      if (profilePicture) formData.append("profilePicture", profilePicture);
      if (idCardFront) formData.append("idCardFront", idCardFront);
      if (idCardBack) formData.append("idCardBack", idCardBack);

      const url = userId ? `/users/api/update/${userId}` : "/users/api/create";
      const method = "POST";

      try {
        const response = await fetch(url, {
          method,
          body: formData, // Send FormData instead of JSON
        });

        const data = await response.json();

        if (!data.success) {
          const errors = Array.isArray(data.errors) ? data.errors.join("<br>") : data.error;
          showAlert("خطأ", errors, "error");
          return;
        }

        showAlert("نجاح", data.message, "success");
        bootstrap.Modal.getInstance(document.getElementById("addUserModal")).hide();
        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        showAlert("خطأ", error.message, "error");
      }
    }

    // Toggle user status
    async function toggleStatus(userId) {
      if (!confirm("هل تريد تغيير حالة المستخدم؟")) return;

      try {
        const response = await fetch(`/users/api/toggle-status/${userId}`, {
          method: "POST",
        });

        const data = await response.json();

        if (!data.success) {
          showAlert("خطأ", data.error, "error");
          return;
        }

        showAlert("نجاح", data.message, "success");
        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        showAlert("خطأ", error.message, "error");
      }
    }

    // Delete user
    async function deleteUser(userId) {
      if (!confirm("هل أنت متأكد من حذف هذا المستخدم؟ لا يمكن التراجع عن هذه العملية.")) return;

      try {
        const response = await fetch(`/users/api/delete/${userId}`, {
          method: "DELETE",
        });

        const data = await response.json();

        if (!data.success) {
          showAlert("خطأ", data.error, "error");
          return;
        }

        showAlert("نجاح", data.message, "success");
        setTimeout(() => location.reload(), 1500);
      } catch (error) {
        showAlert("خطأ", error.message, "error");
      }
    }

    // Download Excel template
    function downloadTemplate() {
      window.location.href = "/users/api/download-template";
    }

    // Show alert (toast)
    function showAlert(title, message, type) {
      const alertClass = type === "error" ? "alert-danger" : "alert-success";
      const alertHTML = `
        <div class="alert ${alertClass} alert-dismissible fade show" role="alert">
          <strong>${title}:</strong> ${message}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      `;

      const alertContainer = document.getElementById("alertContainer") || createAlertContainer();
      alertContainer.innerHTML = alertHTML;

      setTimeout(() => {
        alertContainer.innerHTML = "";
      }, 5000);
    }

    function createAlertContainer() {
      const container = document.createElement("div");
      container.id = "alertContainer";
      container.style.cssText = "position: fixed; top: 20px; right: 20px; z-index: 9999; width: 400px;";
      document.body.appendChild(container);
      return container;
    }

    // Reset form when modal is closed
    document.getElementById("addUserModal")?.addEventListener("hidden.bs.modal", () => {
      document.getElementById("userId").value = "";
      document.getElementById("userForm").reset();
      document.getElementById("modalTitle").textContent = "إضافة مستخدم جديد";
      document.getElementById("password").placeholder = "الكلمة السرية";

      // Hide current attachment displays
      document.getElementById("currentProfilePictureContainer").style.display = "none";
      document.getElementById("currentIdCardFrontContainer").style.display = "none";
      document.getElementById("currentIdCardBackContainer").style.display = "none";

      // Clear file inputs
      document.getElementById("profilePicture").value = "";
      document.getElementById("idCardFront").value = "";
      document.getElementById("idCardBack").value = "";
    });
