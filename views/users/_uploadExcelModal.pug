//- Upload Excel Modal
.modal.fade(id="uploadExcelModal", tabindex="-1")
  .modal-dialog
    .modal-content
      .modal-header
        h5.modal-title رفع مستخدمين من Excel
        button.btn-close(type="button", data-bs-dismiss="modal")

      .modal-body
        .alert.alert-info.mb-3
          i.bi.bi-info-circle.me-2
          | تأكد من أن ملف Excel يحتوي على الأعمدة الصحيحة قبل الرفع

        form#uploadExcelForm
          .mb-3
            label.form-label(for="excelFile")
              | اختر ملف Excel
              span.text-danger *

            input#excelFile.form-control(
              type="file",
              accept=".xlsx,.xls",
              required
            )

          .form-text.text-muted
            small
              | الحد الأقصى لحجم الملف: 5 MB

      .modal-footer
        button.btn.btn-secondary(type="button", data-bs-dismiss="modal")
          | إغلاق

        button.btn.btn-success(type="button", onclick="uploadExcelFile()")
          i.bi.bi-upload.me-2
          | رفع الملف

  script.
    async function uploadExcelFile() {
      const fileInput = document.getElementById("excelFile");
      const file = fileInput.files[0];

      if (!file) {
        showAlert("خطأ", "يجب اختيار ملف", "error");
        return;
      }

      const formData = new FormData();
      formData.append("file", file);

      try {
        const response = await fetch("/users/api/bulk-upload", {
          method: "POST",
          body: formData,
        });

        const data = await response.json();

        if (!data.success) {
          showAlert("خطأ", data.error, "error");
          return;
        }

        // Show results
        let message = data.message + "<br><br>";

        if (data.results.success.length > 0) {
          message += `<strong class="text-success">تم رفعهم بنجاح: ${data.results.success.length}</strong><br>`;
        }

        if (data.results.failed.length > 0) {
          message += `<strong class="text-danger">فشل: ${data.results.failed.length}</strong><br>`;
          data.results.failed.forEach((failed) => {
            message += `• ${failed.user}: ${failed.errors.join(", ")}<br>`;
          });
        }

        showAlert("نتائج الرفع", message, "success");

        setTimeout(() => {
          location.reload();
        }, 2000);
      } catch (error) {
        showAlert("خطأ", error.message, "error");
      }
    }
