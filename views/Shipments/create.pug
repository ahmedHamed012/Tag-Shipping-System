extends ../layouts/layout

block content
  .container-fluid.py-4
    .row.mb-4
      .col-md-8
        h1.mb-0
          i.fas.fa-plus-circle.me-2
          span إنشاء شحنة جديدة
      .col-md-4.text-end
        a.btn.btn-secondary(href="/shipments")
          i.fas.fa-arrow-left.me-2
          span عودة إلى الشحنات

    form#shipmentForm
      .row
        // Left Column: Shipment Details
        .col-lg-8
          .card.mb-4
            .card-header.bg-primary.text-white
              h5.mb-0
                i.fas.fa-info-circle.me-2
                span بيانات الشحنة

            .card-body
              // Merchant Selection
              .mb-3
                label.form-label.fw-bold اختر التاجر *
                select.form-select#merchantSelect(onchange="onMerchantChange()" required)
                  option(value="") -- اختر التاجر --
                  each merchant in merchants
                    option(value=merchant.id data-maxweight=merchant.maxShipmentWeight data-extrafee=merchant.extraWeightFeePerKg)
                      = merchant.name

              // Receiver Search Section
              .card.border-info.mb-3
                .card-header.bg-light
                  h6.mb-0
                    i.fas.fa-search.me-2
                    span ابحث عن المستقبل

                .card-body
                  .row.g-2
                    .col-md-8
                      input.form-control#receiverPhone(
                        type="tel"
                        placeholder="أدخل رقم هاتف المستقبل"
                        maxlength="15"
                      )
                    .col-md-4
                      button.btn.btn-info.w-100(type="button" onclick="searchReceiver()")
                        i.fas.fa-search.me-2
                        span بحث

                  #receiverSearchResult.mt-3(style="display: none;")
                    .alert.alert-success.mb-0
                      .row
                        .col-md-8
                          div
                            strong بيانات المستقبل المجدة
                            div
                              span#foundReceiverName
                        .col-md-4.text-end
                          button.btn.btn-sm.btn-success(type="button" onclick="selectFoundReceiver()")
                            i.fas.fa-check.me-1
                            span استخدم هذا المستقبل

              // Receiver Details (If not found)
              #manualReceiverForm.card.border-warning.mb-3(style="display: none;")
                .card-header.bg-light
                  h6.mb-0
                    i.fas.fa-user.me-2
                    span بيانات المستقبل الجديد

                .card-body
                  .row.g-3
                    .col-md-6
                      input.form-control#receiverFullName(
                        type="text"
                        placeholder="اسم المستقبل الكامل"
                        required
                      )
                    .col-md-6
                      input.form-control#receiverPhone1(
                        type="tel"
                        placeholder="الهاتف الأساسي"
                        required
                      )

                  .row.g-3
                    .col-md-6
                      input.form-control#receiverPhone2(
                        type="tel"
                        placeholder="الهاتف الفرعي (اختياري)"
                      )
                    .col-md-6
                      input.form-control#receiverAddress(
                        type="text"
                        placeholder="العنوان"
                        required
                      )

                  .row.g-3
                    .col-md-6
                      label.form-label.fw-bold المحافظة *
                      select.form-select#receiverGovernorate(
                        onchange="onReceiverGovernorateChange()"
                        required
                      )
                        option(value="") -- اختر المحافظة --
                    .col-md-6
                      label.form-label.fw-bold المدينة *
                      select.form-select#receiverCity(
                        required
                      )
                        option(value="") -- اختر المدينة --

                  .row.g-3
                    .col-md-12
                      textarea.form-control#receiverNotes(
                        rows="2"
                        placeholder="ملاحظات (اختياري)"
                      )

              // Shipment Options
              .card.mb-3
                .card-header
                  h6.mb-0 خيارات الشحنة
                .card-body
                  .row.g-3
                    .col-md-6
                      .form-check.form-check-inline
                        input.form-check-input#isOpenable(
                          type="checkbox"
                          onchange="calculateQuote()"
                        )
                        label.form-check-label(for="isOpenable") قابل للفتح

                    .col-md-6
                      .form-check.form-check-inline
                        input.form-check-input#isFastDelivery(
                          type="checkbox"
                          onchange="calculateQuote()"
                        )
                        label.form-check-label(for="isFastDelivery") توصيل سريع (يزيد السعر 1.5x)

                    .col-md-12
                      input.form-control#policyNumber(
                        type="text"
                        placeholder="رقم الحساب (اختياري)"
                      )

              // Additional Notes
              .mb-3
                label.form-label الملاحظات الإضافية
                textarea.form-control#additionalNotes(
                  rows="3"
                  placeholder="ملاحظات حول الشحنة..."
                )

        // Right Column: Price Calculation
        .col-lg-4
          .card.mb-4.border-success
            .card-header.bg-success.text-white
              h5.mb-0
                i.fas.fa-calculator.me-2
                span حساب التسعيرة

            .card-body
              // Location Selection for Price
              .mb-3
                label.form-label.fw-bold المحافظة *
                select.form-select#priceGovernorate(
                  onchange="onPriceGovernorateChange();calculateQuote();"
                  required
                )
                  option(value="") -- اختر المحافظة --

              .mb-3
                label.form-label.fw-bold المدينة *
                select.form-select#priceCity(
                  onchange="calculateQuote()"
                  required
                )
                  option(value="") -- اختر المدينة --

              hr

              // Weight and Amount
              .mb-3
                label.form-label.fw-bold الوزن الإجمالي (كيلو) *
                input.form-control#amountGained(
                  type="number"
                  step="0.01"
                  placeholder="0.00"
                  onchange="calculateQuote()"
                  required
                )

              hr

              // Price Breakdown
              .bg-light.p-3.rounded.mb-3
                .row.mb-2
                  .col-7
                    small.text-muted السعر الأساسي:
                  .col-5.text-end
                    span#basePrice.fw-bold 0.00

                .row.mb-2(#fastDeliveryRow style="display: none;")
                  .col-7
                    small.text-muted توصيل سريع (1.5x):
                  .col-5.text-end
                    span#fastDeliveryPrice.text-warning.fw-bold 0.00

                .row.mb-2(#extraWeightRow style="display: none;")
                  .col-7
                    small.text-muted رسوم الوزن الزائد:
                  .col-5.text-end
                    span#extraWeightPrice.text-danger.fw-bold 0.00

                .row.pt-2.border-top
                  .col-7
                    strong السعر النهائي:
                  .col-5.text-end
                    strong.text-success(style="font-size: 1.1em;")
                      span#finalPrice 0.00
                      span.ms-1 ج.م

              .alert.alert-info.small
                i.fas.fa-info-circle.me-2
                span الحالة: <strong>طلب بيك اب</strong> (يتم تعيينها تلقائياً)

          // Items Section
          .card
            .card-header.bg-primary.text-white
              h6.mb-0
                i.fas.fa-boxes.me-2
                span المنتجات

            .card-body
              #itemsList
                // Items will be added here dynamically

              .mt-3
                button.btn.btn-outline-primary.w-100(type="button" onclick="addItem()")
                  i.fas.fa-plus-circle.me-2
                  span إضافة منتج

    // Submit Section
    .row.mt-4
      .col-md-12
        .card
          .card-body
            .row.g-2
              .col-md-6
                button.btn.btn-secondary.w-100(type="button" onclick="location.href='/shipments'")
                  i.fas.fa-times.me-2
                  span إلغاء

              .col-md-6
                button.btn.btn-success.w-100(type="button" onclick="submitForm()")
                  i.fas.fa-paper-plane.me-2
                  span إنشاء الشحنة


  script.
    let selectedReceiver = null;
    let itemCounter = 0;

    // Constants for shipment statuses
    const INITIAL_STATUS = "طلب بيك اب";

    function onMerchantChange() {
      const merchantSelect = document.getElementById('merchantSelect');
      if (merchantSelect.value) {
        document.getElementById('priceGovernorate').focus();
      }
    }

    function searchReceiver() {
      const phone = document.getElementById('receiverPhone').value.trim();

      if (!phone || phone.length < 5) {
        alert('أدخل رقم هاتف صحيح (5 أرقام على الأقل)');
        return;
      }

      fetch(`/shipments/api/search-receiver?phone=${encodeURIComponent(phone)}`)
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          selectedReceiver = data.receiver;
          showReceiverSearchResult(data.receiver);
          document.getElementById('manualReceiverForm').style.display = 'none';
        } else {
          selectedReceiver = null;
          document.getElementById('receiverSearchResult').style.display = 'none';
          document.getElementById('manualReceiverForm').style.display = 'block';
          clearManualReceiverForm();
          // Pre-fill phone
          document.getElementById('receiverPhone1').value = phone;
          alert(data.error);
        }
      })
      .catch(err => alert('خطأ: ' + err.message));
    }

    function showReceiverSearchResult(receiver) {
      let html = `
        <div class="row">
          <div class="col-md-8">
            <div>
              <strong>${receiver.fullName}</strong><br>
              <small class="text-muted">${receiver.phone1}</small>
              ${receiver.phone2 ? '<br><small class="text-muted">' + receiver.phone2 + '</small>' : ''}
              <div class="small mt-2">${receiver.governorate} - ${receiver.city}</div>
              <div class="small text-muted">${receiver.address}</div>
            </div>
          </div>
          <div class="col-md-4 text-end">
            <button class="btn btn-sm btn-success" type="button" onclick="selectFoundReceiver()">
              <i class="fas fa-check me-1"></i>اختر
            </button>
          </div>
        </div>
      `;
      document.getElementById('receiverSearchResult').innerHTML = html;
      document.getElementById('receiverSearchResult').style.display = 'block';
    }

    function selectFoundReceiver() {
      if (!selectedReceiver) return;

      // Update location fields from receiver
      document.getElementById('priceGovernorate').value = selectedReceiver.governorate || '';
      document.getElementById('priceCity').value = selectedReceiver.city || '';

      document.getElementById('manualReceiverForm').style.display = 'none';
      calculateQuote();
    }

    function clearManualReceiverForm() {
      document.getElementById('receiverFullName').value = '';
      document.getElementById('receiverPhone1').value = '';
      document.getElementById('receiverPhone2').value = '';
      document.getElementById('receiverAddress').value = '';
      document.getElementById('receiverGovernorate').value = '';
      document.getElementById('receiverCity').value = '';
      document.getElementById('receiverNotes').value = '';
    }

    function calculateQuote() {
      const merchantId = document.getElementById('merchantSelect').value;
      const governorate = document.getElementById('priceGovernorate').value;
      const city = document.getElementById('priceCity').value;
      const amountGained = parseFloat(document.getElementById('amountGained').value) || 0;
      const isFastDelivery = document.getElementById('isFastDelivery').checked;

      if (!merchantId || !governorate || !city || amountGained <= 0) {
        resetPriceDisplay();
        return;
      }

      fetch('/shipments/api/calculate-quote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          merchantId,
          governorate,
          city,
          amountGained,
          isFastDelivery
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          displayPriceBreakdown(data.price);
        } else {
          alert(data.error);
          resetPriceDisplay();
        }
      })
      .catch(err => {
        console.error('Error:', err);
        resetPriceDisplay();
      });
    }

    function displayPriceBreakdown(finalPrice) {
      const merchantSelect = document.getElementById('merchantSelect');
      const selectedOption = merchantSelect.options[merchantSelect.selectedIndex];
      const maxWeight = parseFloat(selectedOption.dataset.maxweight) || 0;
      const extraFee = parseFloat(selectedOption.dataset.extrafee) || 0;
      const amountGained = parseFloat(document.getElementById('amountGained').value) || 0;
      const isFastDelivery = document.getElementById('isFastDelivery').checked;

      // Get price list to calculate base price
      const governorate = document.getElementById('priceGovernorate').value;
      const city = document.getElementById('priceCity').value;
      const merchantId = document.getElementById('merchantSelect').value;

      fetch(`/shipments/api/price-list?merchantId=${merchantId}&governorate=${governorate}&city=${city}`)
      .then(res => res.json())
      .then(data => {
        if (data.success && data.priceList.length > 0) {
          let basePrice = parseFloat(data.priceList[0].price);

          document.getElementById('basePrice').textContent = basePrice.toFixed(2);

          // Fast delivery
          let fastDeliveryPrice = 0;
          if (isFastDelivery) {
            fastDeliveryPrice = basePrice * 0.5; // 1.5x means +50%
            document.getElementById('fastDeliveryPrice').textContent = fastDeliveryPrice.toFixed(2);
            document.getElementById('fastDeliveryRow').style.display = 'block';
          } else {
            document.getElementById('fastDeliveryRow').style.display = 'none';
          }

          // Extra weight
          let extraWeightPrice = 0;
          if (maxWeight > 0 && amountGained > maxWeight && extraFee > 0) {
            const excessWeight = amountGained - maxWeight;
            extraWeightPrice = excessWeight * extraFee;
            document.getElementById('extraWeightPrice').textContent = extraWeightPrice.toFixed(2);
            document.getElementById('extraWeightRow').style.display = 'block';
          } else {
            document.getElementById('extraWeightRow').style.display = 'none';
          }

          document.getElementById('finalPrice').textContent = finalPrice.toFixed(2);
        }
      });
    }

    function resetPriceDisplay() {
      document.getElementById('basePrice').textContent = '0.00';
      document.getElementById('fastDeliveryPrice').textContent = '0.00';
      document.getElementById('extraWeightPrice').textContent = '0.00';
      document.getElementById('finalPrice').textContent = '0.00';
      document.getElementById('fastDeliveryRow').style.display = 'none';
      document.getElementById('extraWeightRow').style.display = 'none';
    }

    function addItem() {
      itemCounter++;
      const itemHtml = `
        <div class="item-row card mb-2" id="item-${itemCounter}">
          <div class="card-body">
            <div class="row g-2">
              <div class="col-md-8">
                <input class="form-control form-control-sm" type="text" placeholder="اسم المنتج" required data-item="${itemCounter}" data-field="productName">
              </div>
              <div class="col-md-4 text-end">
                <button class="btn btn-sm btn-danger" type="button" onclick="removeItem(${itemCounter})">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>

            <div class="row g-2 mt-2">
              <div class="col-md-6">
                <input class="form-control form-control-sm" type="text" placeholder="الوصف" data-item="${itemCounter}" data-field="productDescription">
              </div>
              <div class="col-md-3">
                <input class="form-control form-control-sm" type="number" step="0.01" placeholder="الوزن" data-item="${itemCounter}" data-field="netWeight">
              </div>
              <div class="col-md-3">
                <input class="form-control form-control-sm" type="text" placeholder="الحجم" data-item="${itemCounter}" data-field="size">
              </div>
            </div>

            <div class="row g-2 mt-2">
              <div class="col-md-12">
                <input class="form-control form-control-sm" type="number" min="1" value="1" placeholder="الكمية" data-item="${itemCounter}" data-field="count">
              </div>
            </div>
          </div>
        </div>
      `;
      document.getElementById('itemsList').insertAdjacentHTML('beforeend', itemHtml);
    }

    function removeItem(itemId) {
      document.getElementById(`item-${itemId}`).remove();
    }

    function getItemsData() {
      const items = [];
      document.querySelectorAll('.item-row').forEach(itemRow => {
        const itemData = {};
        itemRow.querySelectorAll('input').forEach(input => {
          const field = input.dataset.field;
          itemData[field] = input.value;
        });
        if (itemData.productName) {
          items.push(itemData);
        }
      });
      return items;
    }

    function submitForm() {
      // Validate merchant
      const merchantId = document.getElementById('merchantSelect').value;
      if (!merchantId) {
        alert('اختر التاجر');
        return;
      }

      // Validate location
      const governorate = document.getElementById('priceGovernorate').value;
      const city = document.getElementById('priceCity').value;
      if (!governorate || !city) {
        alert('أدخل المحافظة والمدينة');
        return;
      }

      // Get or validate receiver
      let receiverId;
      if (selectedReceiver) {
        receiverId = selectedReceiver.id;
      } else {
        // Validate manual receiver form
        const fullName = document.getElementById('receiverFullName').value;
        const phone1 = document.getElementById('receiverPhone1').value;
        const address = document.getElementById('receiverAddress').value;
        const recGovernorate = document.getElementById('receiverGovernorate').value;
        const recCity = document.getElementById('receiverCity').value;

        if (!fullName || !phone1 || !address || !recGovernorate || !recCity) {
          alert('أكمل بيانات المستقبل');
          return;
        }

        // For now, we'll need to create receiver first or get ID
        // This requires additional backend logic
        alert('يجب اختيار مستقبل موجود أو سيتم إضافة الخاصية لإنشاء مستقبل جديد');
        return;
      }

      // Validate items
      const items = getItemsData();
      if (items.length === 0) {
        alert('أضف على الأقل منتج واحد');
        return;
      }

      // Validate amount
      const amountGained = parseFloat(document.getElementById('amountGained').value);
      if (!amountGained || amountGained <= 0) {
        alert('أدخل الوزن الإجمالي');
        return;
      }

      // Get total amount (from displayed price)
      const totalAmount = parseFloat(document.getElementById('finalPrice').textContent);
      if (totalAmount <= 0) {
        alert('احسب التسعيرة أولاً');
        return;
      }

      // Prepare data
      const shipmentData = {
        merchantId,
        receiverId,
        policyNumber: document.getElementById('policyNumber').value || null,
        isOpenable: document.getElementById('isOpenable').checked,
        isFastDelivery: document.getElementById('isFastDelivery').checked,
        totalAmount,
        amountGained,
        additionalNotes: document.getElementById('additionalNotes').value || null,
        items
      };

      // Submit
      fetch('/shipments/api/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(shipmentData)
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          showAlert('success', data.message);
          setTimeout(() => location.href = '/shipments', 2000);
        } else {
          showAlert('error', data.error);
        }
      })
      .catch(err => showAlert('error', err.message));
    }

    function showAlert(type, message) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type === 'error' ? 'danger' : 'success'} alert-dismissible fade show`;
      alertDiv.innerHTML = `
        <i class="fas fa-${type === 'error' ? 'times-circle' : 'check-circle'} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      `;
      document.body.insertAdjacentElement('afterbegin', alertDiv);
      setTimeout(() => alertDiv.remove(), 5000);
    }

    // Initialize governorates and cities
    let governoratesMap = {};

    async function initializeGovernorates() {
      try {
        const response = await fetch('/countries/api/governorates-dropdown');
        const data = await response.json();
        
        if (data.success) {
          const receiverGovSelect = document.getElementById('receiverGovernorate');
          const priceGovSelect = document.getElementById('priceGovernorate');
          
          data.data.forEach(gov => {
            governoratesMap[gov.id] = gov;
            
            const option1 = document.createElement('option');
            option1.value = gov.nameAr;
            option1.textContent = gov.nameAr;
            option1.dataset.id = gov.id;
            receiverGovSelect.appendChild(option1);
            
            const option2 = document.createElement('option');
            option2.value = gov.nameAr;
            option2.textContent = gov.nameAr;
            option2.dataset.id = gov.id;
            priceGovSelect.appendChild(option2);
          });
        }
      } catch (error) {
        console.error('Error loading governorates:', error);
      }
    }

    function onReceiverGovernorateChange() {
      const select = document.getElementById('receiverGovernorate');
      const citySelect = document.getElementById('receiverCity');
      const selectedOption = select.options[select.selectedIndex];
      const govId = selectedOption.dataset.id;
      
      citySelect.innerHTML = '<option value="">-- اختر المدينة --</option>';
      
      if (govId) {
        loadCitiesByGovernorate(govId, citySelect);
      }
    }

    function onPriceGovernorateChange() {
      const select = document.getElementById('priceGovernorate');
      const citySelect = document.getElementById('priceCity');
      const selectedOption = select.options[select.selectedIndex];
      const govId = selectedOption.dataset.id;
      
      citySelect.innerHTML = '<option value="">-- اختر المدينة --</option>';
      
      if (govId) {
        loadCitiesByGovernorate(govId, citySelect);
      }
    }

    async function loadCitiesByGovernorate(govId, selectElement) {
      try {
        const response = await fetch(`/countries/api/cities/${govId}`);
        const data = await response.json();
        
        if (data.success) {
          data.cities.forEach(city => {
            const option = document.createElement('option');
            option.value = city.nameAr;
            option.textContent = city.nameAr;
            selectElement.appendChild(option);
          });
        }
      } catch (error) {
        console.error('Error loading cities:', error);
      }
    }

    // Initialize when page loads
    document.addEventListener('DOMContentLoaded', function() {
      initializeGovernorates();
    });

    // Initialize with one empty item
    addItem();
  