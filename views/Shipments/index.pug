extends ../layouts/layout

block content
  .container-fluid.py-4(style="overflow-x:hidden")
    .row.mb-4
      .col-md-8
        h1.mb-0
          i.bi.bi-box-seam-fill.me-2
          span الشحنات
      .col-md-4.text-end
        button.btn.btn-success.me-2(onclick="openBarcodeModal()" title="مسح باركود")
          i.bi.bi-upc-scan.me-2
          span مسح باركود
        a.btn.btn-primary(href="/shipments/create")
          i.bi.bi-plus.me-2
          span إنشاء شحنة جديدة

    // Filters
    .card.mb-4
      .card-body.p-2
        .d-flex.gap-2.align-items-end.flex-nowrap.pb-1(style="overflow-x:auto")
          div(style="min-width:160px")
            label.form-label.small.mb-1 بحث عام
            input.form-control.form-control-sm(
              type="text"
              id="searchInput"
              placeholder="بحث..."
              value=search
            )
          div(style="min-width:160px")
            label.form-label.small.mb-1 التاجر
            select.form-select.form-select-sm(id="merchantFilter")
              option(value="") كل التجار
              each merchant in merchants
                option(value=merchant.id selected=(merchantId === merchant.id))= merchant.name
          div(style="min-width:150px")
            label.form-label.small.mb-1 الحالة
            select.form-select.form-select-sm(id="statusFilter")
              option(value="") كل الحالات
              option(value="طلب بيك اب" selected=(status === "طلب بيك اب")) طلب بيك اب
              option(value="تم الاستقبال" selected=(status === "تم الاستقبال")) تم الاستقبال
              option(value="قيد التوصيل" selected=(status === "قيد التوصيل")) قيد التوصيل
              option(value="تم التوصيل" selected=(status === "تم التوصيل")) تم التوصيل
              option(value="تسليم جزئي" selected=(status === "تسليم جزئي")) تسليم جزئي
              option(value="استبدال" selected=(status === "استبدال")) استبدال
              option(value="مرتجع مع دفع الشحن" selected=(status === "مرتجع مع دفع الشحن")) مرتجع مع دفع الشحن
              option(value="رفض التسليم مع دفع الشحن" selected=(status === "رفض التسليم مع دفع الشحن")) رفض التسليم مع دفع الشحن
              option(value="ملغاة" selected=(status === "ملغاة")) ملغاة
              option(value="مؤجل" selected=(status === "مؤجل")) مؤجل
              option(value="مرتجع للمستودع" selected=(status === "مرتجع للمستودع")) مرتجع للمستودع
              option(value="مرتجع" selected=(status === "مرتجع")) مرتجع
              option(value="مرتجع للتاجر" selected=(status === "مرتجع للتاجر")) مرتجع للتاجر
              option(value="مرتجع جزئي" selected=(status === "مرتجع جزئي")) مرتجع جزئي
              option(value="مرتجع استبدال" selected=(status === "مرتجع استبدال")) مرتجع استبدال
          div(style="min-width:145px")
            label.form-label.small.mb-1 من تاريخ
            input.form-control.form-control-sm(type="date" id="dateFromFilter" value=dateFrom)
          div(style="min-width:145px")
            label.form-label.small.mb-1 إلى تاريخ
            input.form-control.form-control-sm(type="date" id="dateToFilter" value=dateTo)
          div(style="min-width:155px")
            label.form-label.small.mb-1 اسم العميل
            input.form-control.form-control-sm(type="text" id="customerNameFilter" placeholder="اسم العميل" value=customerName)
          div(style="min-width:145px")
            label.form-label.small.mb-1 هاتف العميل
            input.form-control.form-control-sm(type="text" id="customerPhoneFilter" placeholder="رقم الهاتف" value=customerPhone)
          div(style="min-width:145px")
            label.form-label.small.mb-1 المحافظة
            input.form-control.form-control-sm(type="text" id="governorateFilter" placeholder="المحافظة" value=governorate)
          div(style="min-width:145px")
            label.form-label.small.mb-1 المنطقة
            input.form-control.form-control-sm(type="text" id="areaFilter" placeholder="المنطقة" value=area)
          div(style="min-width:155px")
            label.form-label.small.mb-1 المندوب
            select.form-select.form-select-sm(id="courierFilter")
              option(value="") كل المناديب
              each courier in couriers
                option(value=courier.id selected=(courierId == courier.id)) #{courier.fullName}
          div(style="min-width:80px")
            label.form-label.small.mb-1 عدد النتائج
            select.form-select.form-select-sm(id="limitSelect")
              option(value="10" selected=(limit === 10)) 10
              option(value="20" selected=(limit === 20)) 20
              option(value="50" selected=(limit === 50)) 50
          div.d-flex.align-items-end(style="min-width:80px")
            button.btn.btn-sm.btn-outline-secondary.w-100(onclick="resetFilters()")
              i.bi.bi-arrow-repeat

    // Shipments Table
    .card
      .table-responsive(style="overflow-x:auto")
        table.table.shipment-table.table-hover.table-sm.mb-0(style="min-width:1100px")
          thead.table-light
            tr
              th.text-center(style="width:130px") رقم الشحنة
              th التاجر
              th اسم العميل
              th هاتف العميل
              th المحافظة
              th المنطقة
              th المندوب
              th(style="width:90px") تاريخ الإنشاء
              th.text-center(style="width:120px") الحالة
              th.text-center(style="width:100px") المبلغ
              th.text-center(style="width:90px") الوزن
              th.text-center(style="width:100px") الإجراءات

          tbody
            if shipments && shipments.length > 0
              each shipment in shipments
                tr
                  td.text-center.fw-bold
                    a(href="/shipments/" + shipment.id style="text-decoration:underline;color:inherit")
                      span.badge.bg-info
                        = shipment.policyNumber || ("SH-" + shipment.id)
                  td= shipment.merchant.name
                  td= shipment.receiver.fullName
                  td= shipment.receiver.phone1
                  td= shipment.receiver.governorate || "-"
                  td= shipment.receiver.city || "-"
                  td= shipment.courier ? shipment.courier.fullName : "-"
                  td= new Date(shipment.createdAt).toLocaleDateString("ar-EG")
                  td.text-center
                    - var statusColors = {"طلب بيك اب":"warning","تم الاستقبال":"info","قيد التوصيل":"primary","تم التوصيل":"success","تسليم جزئي":"warning","استبدال":"info","مرتجع مع دفع الشحن":"secondary","رفض التسليم مع دفع الشحن":"secondary","ملغاة":"danger","مؤجل":"secondary","مرتجع للمستودع":"dark","مرتجع":"dark","مرتجع للتاجر":"dark","مرتجع جزئي":"warning","مرتجع استبدال":"info"}
                    - var statusColor = statusColors[shipment.shipmentStatus] || "secondary"
                    span.badge(class="bg-" + statusColor)= shipment.shipmentStatus
                    .mt-1
                      button.btn.btn-sm.btn-outline-primary(
                        onclick="updateStatus(" + shipment.id + ")"
                        data-bs-toggle="modal"
                        data-bs-target="#statusModal"
                        title="تغيير الحالة"
                      )
                        i.bi.bi-pencil
                  td.text-center.fw-bold
                    span(id="total-" + shipment.id)= parseFloat(shipment.totalAmount).toFixed(2) + " ج.م"
                    button.btn.btn-link.btn-sm.p-0.ms-1.text-secondary(
                      title="تعديل المبلغ"
                      onclick="openEditTotal(" + shipment.id + ", " + parseFloat(shipment.totalAmount) + ")"
                      style="vertical-align:baseline"
                    )
                      i.bi.bi-pencil-fill(style="font-size:0.7rem")
                  td.text-center= parseFloat(shipment.amountGained).toFixed(2) + " ك"
                  td.text-center
                    button.btn.btn-sm.btn-info(onclick="viewShipment(" + shipment.id + ")" title="عرض")
                      i.bi.bi-eye
                    button.btn.btn-sm.btn-danger.ms-1(onclick="deleteShipment(" + shipment.id + ")" title="حذف")
                      i.bi.bi-trash
            else
              tr
                td.text-center.py-4(colspan="12")
                  p.text-muted.mb-0 لا توجد شحنات

    // Pagination
    .row.mt-4
      .col-md-6
        p.text-muted= "إجمالي الشحنات: " + totalShipments
      .col-md-6
        nav(aria-label="Page navigation").float-end
          ul.pagination.mb-0
            if currentPage > 1
              li.page-item
                a.page-link(href="javascript:void(0)" onclick="goPage(1)") أول
              li.page-item
                a.page-link(href="javascript:void(0)" onclick=`goPage(${currentPage - 1})`) السابق
            - for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++)
              if i === currentPage
                li.page-item.active
                  span.page-link= i
              else
                li.page-item
                  a.page-link(href="javascript:void(0)" onclick=`goPage(${i})`)= i
            if currentPage < totalPages
              li.page-item
                a.page-link(href="javascript:void(0)" onclick=`goPage(${currentPage + 1})`) التالي
              li.page-item
                a.page-link(href="javascript:void(0)" onclick=`goPage(${totalPages})`) أخير

    // ── Single Status Update Modal ──────────────────────────────────────
    #statusModal.modal.fade(tabindex="-1")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title تحديث حالة الشحنة
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            input#currentShipmentId(type="hidden")
            input#currentShipmentStatus(type="hidden")
            .mb-3
              label.form-label.small.text-muted الحالة الحالية
              p#currentStatusDisplay.fw-bold.mb-0 -
            .mb-3
              label.form-label الحالة الجديدة
              select.form-select#newStatus(onchange="onNewStatusChange()")
                option(value="") اختر الحالة
            #collectedAmountField.mb-3(style="display:none")
              label.form-label المبلغ المحصل من العميل
              input.form-control#collectedAmount(type="number" min="0" step="0.01" placeholder="0.00")
            #shippingAmountField.mb-3(style="display:none")
              label.form-label مبلغ الشحن المحصل من العميل
              input.form-control#shippingAmount(type="number" min="0" step="0.01" placeholder="0.00")
            #courierField.mb-3(style="display:none")
              label.form-label مندوب الاستلام
              select.form-select#pickupCourier
                option(value="") اختر المندوب
                each courier in couriers
                  option(value=courier.id)= courier.fullName
            #deliveryCourierField.mb-3(style="display:none")
              label.form-label مندوب التوصيل
              select.form-select#deliveryCourier
                option(value="") اختر المندوب
                each courier in couriers
                  option(value=courier.id)= courier.fullName
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") إغلاق
            button.btn.btn-primary(type="button" onclick="saveStatusChange()") حفظ

    // ── Shipment Details Modal ──────────────────────────────────────────
    #shipmentDetailsModal.modal.fade(tabindex="-1")
      .modal-dialog.modal-lg
        .modal-content
          .modal-header
            h5.modal-title تفاصيل الشحنة
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body#shipmentDetailsBody

    // ── Edit Total Modal ────────────────────────────────────────────────
    #editTotalModal.modal.fade(tabindex="-1")
      .modal-dialog.modal-sm
        .modal-content
          .modal-header.py-2
            h6.modal-title.mb-0
              i.bi.bi-pencil-fill.me-2
              | تعديل المبلغ الإجمالي
            button.btn-close.btn-sm(type="button" data-bs-dismiss="modal")
          .modal-body
            input#editTotalShipmentId(type="hidden")
            .mb-1
              label.form-label.small.text-muted المبلغ الحالي
              p#editTotalCurrentDisplay.fw-bold.mb-0 -
            .mt-2
              label.form-label.small المبلغ الجديد (ج.م)
              input.form-control#editTotalInput(
                type="number"
                min="0"
                step="0.01"
                placeholder="0.00"
              )
          .modal-footer.py-2
            button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") إلغاء
            button.btn.btn-sm.btn-primary(type="button" onclick="saveEditTotal()") حفظ

    // ── Barcode Scanner Modal ───────────────────────────────────────────
    #barcodeModal.modal.fade(tabindex="-1")
      .modal-dialog.modal-xl
        .modal-content
          .modal-header
            h5.modal-title
              i.bi.bi-upc-scan.me-2
              span مسح الباركود
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            .row.mb-3
              .col
                .input-group
                  input.form-control#barcodeInput(
                    type="text"
                    placeholder="امسح الباركود أو اكتبه ثم اضغط Enter..."
                    autocomplete="off"
                    autofocus
                  )
                  button.btn.btn-primary(type="button" onclick="scanBarcode()")
                    i.bi.bi-search
            .table-responsive
              table.table.table-sm.table-hover
                thead.table-light
                  tr
                    th.text-center(style="width:40px")
                      input.form-check-input#selectAll(type="checkbox" onchange="toggleSelectAll(this)")
                    th رقم الشحنة
                    th التاجر
                    th العميل
                    th المحافظة
                    th المنطقة
                    th.text-center الحالة الحالية
                tbody#barcodeTableBody
                  tr#barcodePlaceholder
                    td.text-center.text-muted.py-3(colspan="7") لم يتم مسح أي شحنة بعد
            #barcodeAlert
          .modal-footer
            .d-flex.align-items-center.gap-2.w-100
              select.form-select.form-select-sm(id="bulkNewStatus" style="max-width:220px")
                option(value="") اختر الحالة الجديدة
                option(value="تم الاستقبال") تم الاستقبال
                option(value="قيد التوصيل") قيد التوصيل
                option(value="تم التوصيل") تم التوصيل
                option(value="رفض التسليم مع دفع الشحن") رفض التسليم مع دفع الشحن
                option(value="ملغاة") ملغاة
                option(value="مؤجل") مؤجل
                option(value="مرتجع للمستودع") مرتجع للمستودع
                option(value="مرتجع") مرتجع
                option(value="مرتجع للتاجر") مرتجع للتاجر
              button.btn.btn-primary(type="button" onclick="bulkUpdateStatus()")
                i.bi.bi-check-all.me-1
                span تحديث المحددة
              button.btn.btn-outline-danger.ms-auto(type="button" onclick="clearBarcodeTable()")
                i.bi.bi-trash.me-1
                span مسح الكل
              button.btn.btn-secondary(type="button" data-bs-dismiss="modal") إغلاق

  script.
    // ── Filters ──────────────────────────────────────────────────────────

    function getFilterParams() {
      return new URLSearchParams({
        page: 1,
        limit: document.getElementById('limitSelect').value,
        search: document.getElementById('searchInput').value,
        status: document.getElementById('statusFilter').value,
        merchantId: document.getElementById('merchantFilter').value,
        dateFrom: document.getElementById('dateFromFilter').value,
        dateTo: document.getElementById('dateToFilter').value,
        customerName: document.getElementById('customerNameFilter').value,
        customerPhone: document.getElementById('customerPhoneFilter').value,
        governorate: document.getElementById('governorateFilter').value,
        area: document.getElementById('areaFilter').value,
        courierId: document.getElementById('courierFilter').value,
      }).toString();
    }

    function updateFilters() {
      window.location.href = '/shipments?' + getFilterParams();
    }

    function goPage(page) {
      const params = new URLSearchParams(getFilterParams());
      params.set('page', page);
      window.location.href = '/shipments?' + params.toString();
    }

    function resetFilters() {
      window.location.href = '/shipments';
    }

    ['searchInput', 'customerNameFilter', 'customerPhoneFilter', 'governorateFilter', 'areaFilter'].forEach(id => {
      document.getElementById(id).addEventListener('change', updateFilters);
    });
    ['statusFilter', 'merchantFilter', 'courierFilter', 'limitSelect', 'dateFromFilter', 'dateToFilter'].forEach(id => {
      document.getElementById(id).addEventListener('change', updateFilters);
    });

    // ── Status Lifecycle ─────────────────────────────────────────────────

    const ALLOWED_TRANSITIONS = {
      'طلب بيك اب':                    ['تم الاستقبال'],
      'تم الاستقبال':                   ['قيد التوصيل', 'ملغاة'],
      'قيد التوصيل':                    ['تم التوصيل', 'تسليم جزئي', 'استبدال', 'مرتجع مع دفع الشحن', 'رفض التسليم مع دفع الشحن', 'مؤجل'],
      'مرتجع مع دفع الشحن':             ['تم الاستقبال'],
      'رفض التسليم مع دفع الشحن':       ['مرتجع للمستودع'],
      'مؤجل':                           ['مرتجع للمستودع'],
      'مرتجع للمستودع':                 ['مرتجع', 'مرتجع للتاجر'],
      'مرتجع جزئي':                     ['مرتجع للمستودع'],
      'مرتجع استبدال':                  ['تم الاستقبال'],
    };
    const REQUIRES_PICKUP_COURIER_FROM = ['مرتجع مع دفع الشحن', 'مرتجع استبدال'];

    // ── Single Status Update ─────────────────────────────────────────────

    function updateStatus(shipmentId) {
      document.getElementById('currentShipmentId').value = shipmentId;
      hideConditionalFields();

      fetch(`/shipments/api/get/${shipmentId}`)
      .then(r => r.json())
      .then(data => {
        if (!data.success) { showAlert('error', data.error); return; }
        const currentStatus = data.shipment.shipmentStatus;
        document.getElementById('currentShipmentStatus').value = currentStatus;
        document.getElementById('currentStatusDisplay').textContent = currentStatus;

        const allowed = ALLOWED_TRANSITIONS[currentStatus] || [];
        const select = document.getElementById('newStatus');
        select.innerHTML = allowed.length
          ? '<option value="">اختر الحالة</option>' + allowed.map(s => `<option value="${s}">${s}</option>`).join('')
          : '<option value="">لا توجد حالات متاحة</option>';
        select.disabled = allowed.length === 0;
      })
      .catch(err => showAlert('error', err.message));
    }

    function onNewStatusChange() {
      const newStatus = document.getElementById('newStatus').value;
      const currentStatus = document.getElementById('currentShipmentStatus').value;
      hideConditionalFields();
      if (newStatus === 'تسليم جزئي')
        document.getElementById('collectedAmountField').style.display = '';
      if (newStatus === 'مرتجع مع دفع الشحن')
        document.getElementById('shippingAmountField').style.display = '';
      if (newStatus === 'تم الاستقبال' && REQUIRES_PICKUP_COURIER_FROM.includes(currentStatus))
        document.getElementById('courierField').style.display = '';
      if (newStatus === 'قيد التوصيل')
        document.getElementById('deliveryCourierField').style.display = '';
    }

    function hideConditionalFields() {
      ['collectedAmountField','shippingAmountField','courierField','deliveryCourierField'].forEach(id => {
        document.getElementById(id).style.display = 'none';
      });
      document.getElementById('collectedAmount').value = '';
      document.getElementById('shippingAmount').value = '';
      document.getElementById('pickupCourier').value = '';
      document.getElementById('deliveryCourier').value = '';
    }

    function saveStatusChange() {
      const shipmentId = document.getElementById('currentShipmentId').value;
      const newStatus = document.getElementById('newStatus').value;
      const currentStatus = document.getElementById('currentShipmentStatus').value;
      if (!newStatus) { showAlert('error', 'اختر الحالة الجديدة'); return; }

      const body = { shipmentStatus: newStatus };

      if (newStatus === 'تسليم جزئي') {
        const amt = document.getElementById('collectedAmount').value;
        if (!amt) { showAlert('error', 'أدخل المبلغ المحصل من العميل'); return; }
        body.collectedAmount = parseFloat(amt);
      }

      if (newStatus === 'مرتجع مع دفع الشحن') {
        const amt = document.getElementById('shippingAmount').value;
        if (!amt) { showAlert('error', 'أدخل مبلغ الشحن المحصل'); return; }
        body.collectedAmount = parseFloat(amt);
      }

      if (newStatus === 'تم الاستقبال' && REQUIRES_PICKUP_COURIER_FROM.includes(currentStatus)) {
        const courierId = document.getElementById('pickupCourier').value;
        if (!courierId) { showAlert('error', 'حدد مندوب الاستلام'); return; }
        body.courierId = parseInt(courierId);
      }

      if (newStatus === 'قيد التوصيل') {
        const courierId = document.getElementById('deliveryCourier').value;
        if (!courierId) { showAlert('error', 'حدد مندوب التوصيل'); return; }
        body.courierId = parseInt(courierId);
      }

      fetch(`/shipments/api/update-status/${shipmentId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      })
      .then(r => r.json())
      .then(data => {
        bootstrap.Modal.getInstance(document.getElementById('statusModal')).hide();
        if (data.success) { showAlert('success', data.message); setTimeout(() => location.reload(), 1200); }
        else showAlert('error', data.error);
      })
      .catch(err => showAlert('error', err.message));
    }

    // ── View Shipment ────────────────────────────────────────────────────

    function viewShipment(shipmentId) {
      fetch(`/shipments/api/get/${shipmentId}`)
      .then(r => r.json())
      .then(data => {
        if (!data.success) { showAlert('error', data.error); return; }
        const s = data.shipment;
        let itemsHtml = s.items.map(item => `
          <tr>
            <td>${item.productName}</td>
            <td>${item.count}</td>
            <td>${item.netWeight || '-'}</td>
            <td>${item.size || '-'}</td>
            <td>${parseFloat(item.price || 0).toFixed(2)} ج.م</td>
          </tr>`).join('');

        const policyNum = s.policyNumber || 'SH-' + s.id;
        document.getElementById('shipmentDetailsBody').innerHTML = `
          <div class="row mb-3">
            <div class="col-md-6"><h6 class="text-muted">رقم الشحنة</h6><p class="fw-bold">${policyNum}</p></div>
            <div class="col-md-6"><h6 class="text-muted">الحالة</h6><span class="badge bg-info">${s.shipmentStatus}</span></div>
          </div><hr>
          <div class="row mb-3">
            <div class="col-md-6"><h6 class="text-muted">التاجر</h6><p class="fw-bold">${s.merchant.name}</p><small class="text-muted">${s.merchant.phone}</small></div>
            <div class="col-md-6"><h6 class="text-muted">العميل</h6><p class="fw-bold">${s.receiver.fullName}</p><small class="text-muted">${s.receiver.phone1}</small><div class="small text-muted">${s.receiver.governorate || ''} ${s.receiver.city ? '- ' + s.receiver.city : ''}</div></div>
          </div><hr>
          <div class="row mb-3">
            <div class="col-md-4"><h6 class="text-muted">المبلغ الإجمالي</h6><p class="fw-bold text-success">${parseFloat(s.totalAmount).toFixed(2)} ج.م</p></div>
            <div class="col-md-4"><h6 class="text-muted">الوزن</h6><p class="fw-bold">${parseFloat(s.amountGained).toFixed(2)} كيلو</p></div>
            <div class="col-md-4"><h6 class="text-muted">المندوب</h6><p class="fw-bold">${s.courier ? s.courier.fullName : '-'}</p></div>
          </div><hr>
          <h6>المنتجات</h6>
          <table class="table table-sm"><thead><tr><th>المنتج</th><th>الكمية</th><th>الوزن</th><th>الحجم</th><th>السعر</th></tr></thead><tbody>${itemsHtml}</tbody></table>
          ${s.additionalNotes ? `<p><strong>ملاحظات:</strong> ${s.additionalNotes}</p>` : ''}
          <hr>
          <div class="text-center">
            <h6 class="mb-3">باركود الشحنة</h6>
            <svg id="shipmentBarcode"></svg>
            <div class="mt-3">
              <button class="btn btn-outline-dark" onclick="printBarcode('${policyNum}', '${s.merchant.name}', '${s.receiver.fullName}')">
                <i class="bi bi-printer me-2"></i>طباعة الباركود
              </button>
            </div>
          </div>`;
        new bootstrap.Modal(document.getElementById('shipmentDetailsModal')).show();
        // Render barcode after modal is injected into DOM
        setTimeout(() => {
          try {
            JsBarcode('#shipmentBarcode', policyNum, {
              format: 'CODE128',
              width: 2,
              height: 80,
              displayValue: true,
              fontSize: 16,
              margin: 10,
              font: 'Tajawal',
            });
          } catch(e) { console.error('Barcode error:', e); }
        }, 50);
      })
      .catch(err => showAlert('error', err.message));
    }

    // ── Print Barcode ────────────────────────────────────────────────────

    function printBarcode(policyNumber, merchantName, receiverName) {
      const svg = document.getElementById('shipmentBarcode');
      if (!svg) return;
      const svgData = new XMLSerializer().serializeToString(svg);
      const printWin = window.open('', '_blank', 'width=400,height=300');
      printWin.document.write(`<!DOCTYPE html>
        <html dir="rtl">
        <head>
          <meta charset="UTF-8">
          <title>باركود الشحنة</title>
          <style>
            @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700&display=swap');
            * { font-family: Tajawal, sans-serif; box-sizing: border-box; }
            body { margin: 0; padding: 16px; text-align: center; background: #fff; }
            .label-box { display: inline-block; border: 1px solid #ccc; padding: 12px 20px; border-radius: 8px; }
            .policy { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
            .info { font-size: 11px; color: #555; margin-top: 6px; }
            svg { display: block; margin: 0 auto; }
            @media print {
              body { padding: 0; }
              .label-box { border: none; }
            }
          </style>
        </head>
        <body>
          <div class="label-box">
            <div class="policy">${policyNumber}</div>
            ${svgData}
            <div class="info">${merchantName} — ${receiverName}</div>
          </div>
          <script>window.onload = function(){ window.print(); window.close(); };<\/script>
        </body>
        </html>`);
      printWin.document.close();
    }

    // ── Edit Total ───────────────────────────────────────────────────────

    function openEditTotal(shipmentId, currentTotal) {
      document.getElementById('editTotalShipmentId').value = shipmentId;
      document.getElementById('editTotalCurrentDisplay').textContent = parseFloat(currentTotal).toFixed(2) + ' ج.م';
      document.getElementById('editTotalInput').value = parseFloat(currentTotal).toFixed(2);
      new bootstrap.Modal(document.getElementById('editTotalModal')).show();
      setTimeout(() => {
        const input = document.getElementById('editTotalInput');
        input.focus();
        input.select();
      }, 300);
    }

    function saveEditTotal() {
      const shipmentId = document.getElementById('editTotalShipmentId').value;
      const totalAmount = document.getElementById('editTotalInput').value;
      if (totalAmount === '' || isNaN(parseFloat(totalAmount))) {
        showAlert('error', 'أدخل مبلغاً صحيحاً');
        return;
      }
      fetch(`/shipments/api/update-total/${shipmentId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ totalAmount: parseFloat(totalAmount) })
      })
      .then(r => r.json())
      .then(data => {
        bootstrap.Modal.getInstance(document.getElementById('editTotalModal')).hide();
        if (data.success) {
          document.getElementById('total-' + shipmentId).textContent = parseFloat(data.totalAmount).toFixed(2) + ' ج.م';
          showAlert('success', data.message);
        } else {
          showAlert('error', data.error);
        }
      })
      .catch(err => showAlert('error', err.message));
    }

    // ── Delete ───────────────────────────────────────────────────────────

    function deleteShipment(shipmentId) {
      if (!confirm('هل أنت متأكد من حذف هذه الشحنة؟')) return;
      fetch(`/shipments/api/delete/${shipmentId}`, { method: 'DELETE' })
      .then(r => r.json())
      .then(data => {
        if (data.success) { showAlert('success', data.message); setTimeout(() => location.reload(), 1200); }
        else showAlert('error', data.error);
      })
      .catch(err => showAlert('error', err.message));
    }

    // ── Barcode Scanner ──────────────────────────────────────────────────

    const scannedShipments = {}; // keyed by shipment id

    function openBarcodeModal() {
      const modal = new bootstrap.Modal(document.getElementById('barcodeModal'));
      modal.show();
      document.getElementById('barcodeModal').addEventListener('shown.bs.modal', () => {
        document.getElementById('barcodeInput').focus();
      }, { once: true });
    }

    document.getElementById('barcodeInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); scanBarcode(); }
    });

    document.getElementById('editTotalInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); saveEditTotal(); }
    });

    function scanBarcode() {
      const barcode = document.getElementById('barcodeInput').value.trim();
      if (!barcode) return;
      document.getElementById('barcodeInput').value = '';

      // Check if already scanned
      const existing = Object.values(scannedShipments).find(s => s.policyNumber === barcode || String(s.id) === barcode);
      if (existing) {
        setBarcodeAlert('warning', `الشحنة ${barcode} موجودة بالفعل في القائمة`);
        document.getElementById('barcodeInput').focus();
        return;
      }

      fetch(`/shipments/api/barcode?barcode=${encodeURIComponent(barcode)}`)
      .then(r => r.json())
      .then(data => {
        if (!data.success) { setBarcodeAlert('danger', data.error); return; }
        const s = data.shipment;
        scannedShipments[s.id] = s;
        addBarcodeRow(s);
        setBarcodeAlert('success', `تمت إضافة الشحنة ${s.policyNumber || 'SH-' + s.id}`);
        document.getElementById('barcodeInput').focus();
      })
      .catch(err => setBarcodeAlert('danger', err.message));
    }

    function addBarcodeRow(s) {
      const placeholder = document.getElementById('barcodePlaceholder');
      if (placeholder) placeholder.remove();

      const color = getStatusColor(s.shipmentStatus);

      const tr = document.createElement('tr');
      tr.id = 'brow-' + s.id;
      tr.innerHTML = `
        <td class="text-center"><input class="form-check-input barcode-checkbox" type="checkbox" value="${s.id}" checked></td>
        <td><span class="badge bg-info">${s.policyNumber || 'SH-' + s.id}</span></td>
        <td>${s.merchant.name}</td>
        <td>${s.receiver.fullName}<br><small class="text-muted">${s.receiver.phone1}</small></td>
        <td>${s.receiver.governorate || '-'}</td>
        <td>${s.receiver.city || '-'}</td>
        <td class="text-center"><span class="badge bg-${color}" data-status="${s.shipmentStatus}">${s.shipmentStatus}</span></td>`;
      document.getElementById('barcodeTableBody').appendChild(tr);
    }

    function toggleSelectAll(cb) {
      document.querySelectorAll('.barcode-checkbox').forEach(c => c.checked = cb.checked);
    }

    function clearBarcodeTable() {
      Object.keys(scannedShipments).forEach(k => delete scannedShipments[k]);
      const tbody = document.getElementById('barcodeTableBody');
      tbody.innerHTML = '<tr id="barcodePlaceholder"><td class="text-center text-muted py-3" colspan="7">لم يتم مسح أي شحنة بعد</td></tr>';
      document.getElementById('selectAll').checked = false;
      document.getElementById('barcodeAlert').innerHTML = '';
    }

    function bulkUpdateStatus() {
      const checked = [...document.querySelectorAll('.barcode-checkbox:checked')];
      if (checked.length === 0) { setBarcodeAlert('warning', 'اختر شحنة على الأقل'); return; }

      const newStatus = document.getElementById('bulkNewStatus').value;
      if (!newStatus) { setBarcodeAlert('warning', 'اختر الحالة الجديدة'); return; }

      // Validate all selected have same current status
      const statuses = checked.map(cb => {
        const row = document.getElementById('brow-' + cb.value);
        return row.querySelector('[data-status]').dataset.status;
      });
      const uniqueStatuses = [...new Set(statuses)];
      if (uniqueStatuses.length > 1) {
        let details = checked.map(cb => {
          const row = document.getElementById('brow-' + cb.value);
          const barcode = row.querySelector('.badge.bg-info').textContent.trim();
          const status = row.querySelector('[data-status]').dataset.status;
          return `${barcode} — ${status}`;
        }).join('\n');
        setBarcodeAlert('danger', 'الشحنات المحددة لها حالات مختلفة:\n' + details);
        return;
      }

      const shipmentIds = checked.map(cb => parseInt(cb.value));
      fetch('/shipments/api/bulk-update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ shipmentIds, shipmentStatus: newStatus })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          setBarcodeAlert('success', data.message);
          // Update displayed status badges
          checked.forEach(cb => {
            const row = document.getElementById('brow-' + cb.value);
            const badge = row.querySelector('[data-status]');
            badge.dataset.status = newStatus;
            badge.textContent = newStatus;
            badge.className = 'badge bg-' + getStatusColor(newStatus);
            if (scannedShipments[cb.value]) scannedShipments[cb.value].shipmentStatus = newStatus;
          });
        } else {
          setBarcodeAlert('danger', data.error);
        }
      })
      .catch(err => setBarcodeAlert('danger', err.message));
    }

    function setBarcodeAlert(type, message) {
      const el = document.getElementById('barcodeAlert');
      el.innerHTML = `<div class="alert alert-${type} py-2 mt-2 mb-0" style="white-space:pre-wrap">${message}</div>`;
      setTimeout(() => { if (el.firstChild) el.firstChild.remove(); }, 5000);
    }

    // ── Status Color Helper ──────────────────────────────────────────────

    function getStatusColor(status) {
      const map = {
        'طلب بيك اب':'warning', 'تم الاستقبال':'info', 'قيد التوصيل':'primary',
        'تم التوصيل':'success', 'تسليم جزئي':'warning', 'استبدال':'info',
        'مرتجع مع دفع الشحن':'secondary', 'رفض التسليم مع دفع الشحن':'secondary',
        'ملغاة':'danger', 'مؤجل':'secondary', 'مرتجع للمستودع':'dark',
        'مرتجع':'dark', 'مرتجع للتاجر':'dark', 'مرتجع جزئي':'warning', 'مرتجع استبدال':'info',
      };
      return map[status] || 'secondary';
    }

    // ── Global Alert ─────────────────────────────────────────────────────

    function showAlert(type, message) {
      const alertDiv = document.createElement('div');
      alertDiv.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
      alertDiv.style.zIndex = 9999;
      alertDiv.innerHTML = `${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
      document.body.appendChild(alertDiv);
      setTimeout(() => alertDiv.remove(), 5000);
    }
