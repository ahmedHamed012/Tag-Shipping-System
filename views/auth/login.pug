doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title تسجيل الدخول - نظام الشحن
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600&display=swap")
    style.
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'IBM Plex Sans Arabic', sans-serif;
        direction: rtl;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0c1220;
        position: relative;
        overflow: hidden;
      }

      .grid-bg {
        position: fixed; inset: 0;
        background-image:
          linear-gradient(rgba(234,160,40,0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(234,160,40,0.06) 1px, transparent 1px);
        background-size: 40px 40px;
        pointer-events: none;
        z-index: 0;
      }

      .glow {
        position: fixed;
        width: 500px; height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(234,160,40,0.1) 0%, transparent 70%);
        top: -150px; left: 50%;
        transform: translateX(-50%);
        pointer-events: none;
        z-index: 0;
      }

      .card {
        position: relative;
        z-index: 1;
        background: rgba(255,255,255,0.04);
        border: 0.5px solid rgba(234,160,40,0.25);
        border-radius: 16px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
        margin: 1rem;
        backdrop-filter: blur(12px);
        box-shadow: 0 0 0 1px rgba(234,160,40,0.05), 0 24px 64px rgba(0,0,0,0.4);
        animation: slideUp 0.5s cubic-bezier(0.22,1,0.36,1) both;
      }

      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 0.5rem;
        justify-content: center;
      }

      .brand-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, #EAA028, #BA7517);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
      }

      .brand-icon svg { width: 20px; height: 20px; fill: #0c1220; }

      .brand-name {
        font-size: 18px;
        font-weight: 600;
        color: #f0e6cc;
        letter-spacing: 0.02em;
      }

      .brand-sub {
        font-size: 12px;
        color: rgba(240,230,204,0.4);
        letter-spacing: 0.05em;
        text-align: center;
        margin-bottom: 1.75rem;
        margin-top: 0.25rem;
      }

      .divider {
        height: 0.5px;
        background: linear-gradient(90deg, transparent, rgba(234,160,40,0.3), transparent);
        margin-bottom: 1.75rem;
      }

      .alert-danger {
        background: rgba(226,75,74,0.12);
        border: 0.5px solid rgba(226,75,74,0.4);
        border-radius: 8px;
        padding: 10px 14px;
        margin-bottom: 1.25rem;
        font-size: 13px;
        color: #f09595;
        display: flex; align-items: center; gap: 8px;
      }

      .alert-danger::before {
        content: '⚠';
        flex-shrink: 0;
      }

      .field { margin-bottom: 1.25rem; }

      .field label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: rgba(240,230,204,0.5);
        margin-bottom: 6px;
        letter-spacing: 0.05em;
      }

      .input-wrap {
        position: relative;
        display: flex;
        align-items: center;
      }

      .input-icon {
        position: absolute;
        right: 12px;
        color: rgba(234,160,40,0.5);
        display: flex; align-items: center;
        pointer-events: none;
      }

      .input-icon svg {
        width: 16px; height: 16px;
        stroke: currentColor; fill: none; stroke-width: 1.5;
      }

      .input-wrap input {
        width: 100%;
        background: rgba(255,255,255,0.05);
        border: 0.5px solid rgba(234,160,40,0.2);
        border-radius: 10px;
        padding: 11px 40px 11px 14px;
        font-size: 14px;
        color: #f0e6cc;
        font-family: 'IBM Plex Sans Arabic', sans-serif;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        outline: none;
      }

      .input-wrap input::placeholder { color: rgba(240,230,204,0.22); }

      .input-wrap input:focus {
        border-color: rgba(234,160,40,0.7);
        background: rgba(234,160,40,0.06);
        box-shadow: 0 0 0 3px rgba(234,160,40,0.1);
      }

      .eye-btn {
        position: absolute;
        left: 12px;
        background: none; border: none; cursor: pointer;
        color: rgba(240,230,204,0.3);
        display: flex; align-items: center;
        padding: 0;
        transition: color 0.2s;
      }

      .eye-btn:hover { color: rgba(234,160,40,0.8); }

      .eye-btn svg {
        width: 16px; height: 16px;
        stroke: currentColor; fill: none; stroke-width: 1.5;
      }

      .forgot {
        text-align: left;
        margin-top: -0.75rem;
        margin-bottom: 1.5rem;
      }

      .forgot a {
        font-size: 12px;
        color: rgba(234,160,40,0.6);
        text-decoration: none;
        transition: color 0.2s;
      }

      .forgot a:hover { color: #EAA028; }

      .btn-login {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #EAA028, #BA7517);
        border: none;
        border-radius: 10px;
        font-family: 'IBM Plex Sans Arabic', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: #0c1220;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s, filter 0.15s;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        letter-spacing: 0.02em;
      }

      .btn-login svg {
        width: 18px; height: 18px;
        stroke: #0c1220; fill: none; stroke-width: 2;
      }

      .btn-login:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(234,160,40,0.35);
      }

      .btn-login:active { transform: scale(0.98); }

      .footer-note {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 11px;
        color: rgba(240,230,204,0.22);
        display: flex; align-items: center; justify-content: center; gap: 6px;
      }

      .footer-note svg {
        width: 12px; height: 12px;
        stroke: currentColor; fill: none; stroke-width: 1.5;
      }

  body
    .grid-bg
    .glow

    .card
      .brand
        .brand-icon
          svg(viewBox="0 0 24 24")
            path(d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z")
        span.brand-name نظام الشحن

      p.brand-sub بوابة الدخول الآمنة

      .divider

      if error
        .alert-danger= error

      form(method="POST" action="/auth/login")
        .field
          label(for="identifier") البريد الإلكتروني أو الهاتف
          .input-wrap
            .input-icon
              svg(viewBox="0 0 24 24")
                path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
                circle(cx="12" cy="7" r="4")
            input#identifier(
              type="text"
              name="identifier"
              value=identifier
              placeholder="example@mail.com"
              required
              autofocus
              autocomplete="username"
            )

        .field
          label(for="password") كلمة المرور
          .input-wrap
            .input-icon
              svg(viewBox="0 0 24 24")
                rect(x="3" y="11" width="18" height="11" rx="2")
                path(d="M7 11V7a5 5 0 0 1 10 0v4")
            input#password(
              type="password"
              name="password"
              required
              placeholder="••••••••"
              autocomplete="current-password"
            )
            button.eye-btn(type="button" id="eyeBtn" aria-label="إظهار كلمة المرور")
              svg#eyeIcon(viewBox="0 0 24 24")
                path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
                circle(cx="12" cy="12" r="3")

        .forgot
          a(href="#") نسيت كلمة المرور؟

        button.btn-login(type="submit")
          svg(viewBox="0 0 24 24")
            path(d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4")
            polyline(points="10 17 15 12 10 7")
            line(x1="15" y1="12" x2="3" y2="12")
          | دخول

      .footer-note
        svg(viewBox="0 0 24 24")
          rect(x="3" y="11" width="18" height="11" rx="2")
          path(d="M7 11V7a5 5 0 0 1 10 0v4")
        | محمي بتشفير SSL

    script.
      const eyeBtn = document.getElementById('eyeBtn');
      const passInput = document.getElementById('password');
      let visible = false;

      const eyeOpen = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
      const eyeClosed = `<svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.5"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

      eyeBtn.addEventListener('click', () => {
        visible = !visible;
        passInput.type = visible ? 'text' : 'password';
        eyeBtn.innerHTML = visible ? eyeClosed : eyeOpen;
      });
