doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title تسجيل الدخول — نظام الشحن
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&display=swap")
    style.
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --primary:       #00b074;
        --primary-dark:  #085528;
        --primary-light: rgba(0,176,116,0.10);
        --font:          'Tajawal', sans-serif;
      }

      body {
        font-family: var(--font);
        direction: rtl;
        min-height: 100vh;
        background: #f0f4f2;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      /* subtle pattern */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          radial-gradient(circle at 20% 20%, rgba(0,176,116,0.08) 0%, transparent 50%),
          radial-gradient(circle at 80% 80%, rgba(8,85,40,0.06) 0%, transparent 50%);
        pointer-events: none;
        z-index: 0;
      }

      /* left decorative bar */
      .side-bar {
        position: fixed;
        top: 0; left: 0;
        width: 6px;
        height: 100vh;
        background: linear-gradient(180deg, var(--primary) 0%, var(--primary-dark) 100%);
      }

      /* card */
      .login-card {
        position: relative;
        z-index: 1;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 32px rgba(0,0,0,0.10), 0 1px 4px rgba(0,0,0,0.06);
        width: 100%;
        max-width: 440px;
        margin: 1.5rem;
        overflow: hidden;
        animation: rise 0.45s cubic-bezier(0.22,1,0.36,1) both;
      }

      @keyframes rise {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* top accent strip */
      .card-accent {
        height: 5px;
        background: linear-gradient(90deg, var(--primary) 0%, var(--primary-dark) 100%);
      }

      .card-body {
        padding: 2.25rem 2rem 2rem;
      }

      /* brand */
      .brand {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.75rem;
      }

      .brand-icon {
        width: 46px; height: 46px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(0,176,116,0.3);
      }

      .brand-icon svg { width: 24px; height: 24px; fill: #fff; }

      .brand-text .name {
        font-size: 1.15rem;
        font-weight: 700;
        color: #1a1a2e;
        line-height: 1.2;
      }

      .brand-text .sub {
        font-size: 0.75rem;
        color: #9896a4;
        margin-top: 2px;
      }

      /* divider */
      .divider {
        height: 1px;
        background: #f0f0f4;
        margin-bottom: 1.75rem;
      }

      /* heading */
      .login-heading {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.3rem;
      }

      .login-sub {
        font-size: 0.82rem;
        color: #9896a4;
        margin-bottom: 1.75rem;
      }

      /* error alert */
      .alert-error {
        background: rgba(220,53,69,0.07);
        border: 1px solid rgba(220,53,69,0.2);
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 1.25rem;
        font-size: 0.83rem;
        color: #c0392b;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .alert-error::before { content: '⚠'; flex-shrink: 0; }

      /* field */
      .field { margin-bottom: 1.1rem; }

      .field label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: #464255;
        margin-bottom: 6px;
      }

      .input-wrap {
        position: relative;
        display: flex;
        align-items: center;
      }

      .input-icon {
        position: absolute;
        right: 13px;
        color: var(--primary);
        opacity: 0.6;
        display: flex;
        pointer-events: none;
      }

      .input-icon svg {
        width: 17px; height: 17px;
        stroke: currentColor; fill: none; stroke-width: 1.8;
      }

      .input-wrap input {
        width: 100%;
        background: #f8faf9;
        border: 1.5px solid #e4eae7;
        border-radius: 10px;
        padding: 11px 44px 11px 14px;
        font-size: 0.92rem;
        color: #1a1a2e;
        font-family: var(--font);
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        outline: none;
      }

      .input-wrap input::placeholder { color: #c4c4cc; }

      .input-wrap input:focus {
        border-color: var(--primary);
        background: #fff;
        box-shadow: 0 0 0 3px rgba(0,176,116,0.12);
      }

      /* eye toggle */
      .eye-btn {
        position: absolute;
        left: 12px;
        background: none;
        border: none;
        cursor: pointer;
        color: #c4c4cc;
        display: flex;
        align-items: center;
        padding: 0;
        transition: color 0.2s;
      }

      .eye-btn:hover { color: var(--primary); }

      .eye-btn svg {
        width: 17px; height: 17px;
        stroke: currentColor; fill: none; stroke-width: 1.8;
      }

      /* submit button */
      .btn-login {
        width: 100%;
        margin-top: 0.5rem;
        padding: 12px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        border: none;
        border-radius: 10px;
        font-family: var(--font);
        font-size: 1rem;
        font-weight: 700;
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        letter-spacing: 0.02em;
        transition: filter 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 14px rgba(0,176,116,0.35);
      }

      .btn-login svg {
        width: 18px; height: 18px;
        stroke: #fff; fill: none; stroke-width: 2;
      }

      .btn-login:hover {
        filter: brightness(1.08);
        transform: translateY(-1px);
        box-shadow: 0 8px 22px rgba(0,176,116,0.40);
      }

      .btn-login:active { transform: scale(0.98); filter: brightness(0.97); }

      /* footer */
      .card-footer-note {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 0.72rem;
        color: #c4c4cc;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
      }

      .card-footer-note svg {
        width: 13px; height: 13px;
        stroke: currentColor; fill: none; stroke-width: 1.5;
      }

  body
    .side-bar

    .login-card
      .card-accent

      .card-body
        //- Brand
        .brand
          .brand-icon
            svg(viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg")
              path(d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z")
              path(d="M9 21V12h6v9" fill="rgba(255,255,255,0.25)")
          .brand-text
            .name نظام الشحن
            .sub Shipping Management System

        .divider

        h2.login-heading أهلاً بعودتك
        p.login-sub سجّل دخولك للمتابعة

        if error
          .alert-error= error

        form(method="POST" action="/auth/login")
          .field
            label(for="identifier") البريد الإلكتروني أو الهاتف
            .input-wrap
              .input-icon
                svg(viewBox="0 0 24 24")
                  path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
                  circle(cx="12" cy="7" r="4")
              input#identifier(
                type="text"
                name="identifier"
                value=identifier
                placeholder="example@mail.com"
                required
                autofocus
                autocomplete="username"
              )

          .field
            label(for="password") كلمة المرور
            .input-wrap
              .input-icon
                svg(viewBox="0 0 24 24")
                  rect(x="3" y="11" width="18" height="11" rx="2")
                  path(d="M7 11V7a5 5 0 0 1 10 0v4")
              input#password(
                type="password"
                name="password"
                required
                placeholder="••••••••"
                autocomplete="current-password"
              )
              button.eye-btn(type="button" id="eyeBtn" aria-label="إظهار كلمة المرور")
                svg#eyeIcon(viewBox="0 0 24 24")
                  path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
                  circle(cx="12" cy="12" r="3")

          button.btn-login(type="submit")
            svg(viewBox="0 0 24 24")
              path(d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4")
              polyline(points="10 17 15 12 10 7")
              line(x1="15" y1="12" x2="3" y2="12")
            | تسجيل الدخول

        .card-footer-note
          svg(viewBox="0 0 24 24")
            rect(x="3" y="11" width="18" height="11" rx="2")
            path(d="M7 11V7a5 5 0 0 1 10 0v4")
          | جميع البيانات محمية ومشفّرة

    script.
      const eyeBtn   = document.getElementById('eyeBtn');
      const passInput = document.getElementById('password');
      let visible = false;

      const eyeOpen   = `<svg viewBox="0 0 24 24" style="width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
      const eyeClosed = `<svg viewBox="0 0 24 24" style="width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.8"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;

      eyeBtn.addEventListener('click', () => {
        visible = !visible;
        passInput.type = visible ? 'text' : 'password';
        eyeBtn.innerHTML = visible ? eyeClosed : eyeOpen;
      });
