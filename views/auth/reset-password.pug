doctype html
html(lang="ar" dir="rtl")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title إعادة تعيين كلمة المرور - نظام الشحن
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
  body.bg-light
    .container.py-5
      .row.justify-content-center
        .col-md-6.col-lg-5
          .card.shadow-sm
            .card-body.p-4
              h4.text-center.mb-4
                i.bi.bi-key.me-2
                | إعادة تعيين كلمة المرور

              if error
                .alert.alert-danger= error
              if success
                .alert.alert-success= success

              form(method="POST" action="/auth/reset-password")
                .mb-3
                  label.form-label(for="currentPassword") كلمة المرور الحالية
                  input#currentPassword.form-control(type="password" name="currentPassword" required)

                .mb-3
                  label.form-label(for="newPassword") كلمة المرور الجديدة
                  input#newPassword.form-control(type="password" name="newPassword" minlength="8" required)

                .mb-3
                  label.form-label(for="confirmPassword") تأكيد كلمة المرور
                  input#confirmPassword.form-control(type="password" name="confirmPassword" minlength="8" required)

                .d-grid.gap-2
                  button.btn.btn-primary(type="submit")
                    i.bi.bi-check-circle.me-2
                    | تحديث كلمة المرور
                  a.btn.btn-outline-secondary(href="/dashboard") رجوع
